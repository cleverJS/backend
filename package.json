{
  "name": "@cleverjs/backend",
  "version": "1.11.13",
  "description": "CleverJS Backend",
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cleverJS/backend"
  },
  "main": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./http": {
      "types": "./dist/types/http/index.d.ts",
      "require": "./dist/http/index.js",
      "import": "./dist/http/index.js",
      "default": "./dist/http/index.js"
    },
    "./db/sql": {
      "types": "./dist/types/db/sql/index.d.ts",
      "require": "./dist/db/sql/index.js",
      "import": "./dist/db/sql/index.js",
      "default": "./dist/db/sql/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "core/**/*",
    "guide/**/*",
    "demo/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "swc ./core -d ./dist --strip-leading-paths --source-maps && tsc -p tsconfig.prod.json --emitDeclarationOnly",
    "prebuild": "pnpm clean",
    "clean": "rm -rf dist tsconfig.build.tsbuildinfo",
    "prepublishOnly": "npm run build",
    "test": "npx jest --runInBand --detectOpenHandles --colors --verbose --reporters=default",
    "test:cov": "npx jest --runInBand --detectOpenHandles --colors --verbose --reporters=default --coverage"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "axios": "^1.12.2",
    "fastest-validator": "^1.19.1",
    "redis": "^4.7.0",
    "typed-emitter": "^2.1.0",
    "dotenv": "^16.4.7",
    "path": "^0.12.7",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^11.0.5",
    "winston": "^3.17.0",
    "ms": "^2.1.3"
  },
  "devDependencies": {
    "@types/ms": "^2.1.0",
    "@jest/types": "^30.2.0",
    "@types/pretty-hrtime": "^1.0.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.14",
    "@types/node": "^22.19.13",
    "@elastic/elasticsearch": "=7.17.13",
    "knex": "=3.1.0",
    "fastify": "^5.2.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/cookie": "^11.0.2",
    "@fastify/session": "^11.1.0",
    "google-auth-library": "^9.11.0",
    "sqlite3": "^5.1.7",
    "bcrypt": "^5.1.1",
    "yup": "^1.6.1",
    "@types/bcrypt": "^5.0.2",
    "@swc/wasm": "^1.6.3",
    "express": "^4.21.2",
    "@types/express": "^4.17.21",
    "form-data": "^4.0.0",
    "jsonwebtoken": "^9.0.2",
    "morphism": "^1.12.3",
    "typescript": "=5.7.3",
    "ts-node": "^10.9.2",
    "telegraf": "^4.16.3",
    "piscina": "^4.1.0",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^28.6.0",
    "eslint-plugin-no-loops": "^0.3.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-optimize-regex": "^1.2.1",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-promise": "^6.2.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sort-export-all": "^1.4.1",
    "eslint-plugin-sonarjs": "^1.0.3",
    "@types/md5": "^2.3.5",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2",
    "md5": "^2.3.0",
    "prettier": "^3.3.2",
    "pretty-hrtime": "^1.0.3",
    "ts-jest": "^29.1.5",
    "jest-environment-node": "^29.7.0"
  },
  "peerDependencies": {
    "knex": "=3.1.0",
    "typescript": "=5.7.3",
    "redis": "^4.7.0",
    "fastify": "^5.2.1",
    "express": "^4.21.2",
    "@elastic/elasticsearch": "=7.17.13",
    "axios": "=1.7.9",
    "ws": "^8.18.0",
    "telegraf": "^4.16.3",
    "winston": "^3.16.0",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.10"
  }
}
