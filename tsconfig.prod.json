{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "importHelpers": true,
    "noEmitHelpers": true,

    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "inlineSourceMap": true,
    "inlineSources": true,

    "typeRoots": [],
    "types": []
  },
  "exclude": ["node_modules", "build", "core/**/*.spec.ts", "demo/**/*", "tmp", "tests/**/*.spec.ts", "knexfile.ts", "guide/**/*"],
  "include": ["core/**/*"],
}
