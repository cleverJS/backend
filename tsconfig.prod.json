{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "importHelpers": true,
    "noEmitHelpers": true,
    "declaration": true,
    "declarationDir": "./dist/types",
    "rootDir": "./core",
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": true,

    "typeRoots": [],
    "types": []
  },
  "exclude": ["node_modules", "build", "core/**/*.spec.ts", "demo/**/*", "tmp", "tests/**/*.spec.ts", "knexfile.ts", "guide/**/*"],
  "include": ["core/**/*"],
}
